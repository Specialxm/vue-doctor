{
  "name": "@vue-doctor/rules",
  "version": "0.1.1",
  "description": "Deterministic detection rules for vue-doctor",
  "license": "MIT",
  "author": "Specialxm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Specialxm/vue-doctor.git",
    "directory": "packages/rules"
  },
  "bugs": {
    "url": "https://github.com/Specialxm/vue-doctor/issues"
  },
  "homepage": "https://github.com/Specialxm/vue-doctor#readme",
  "keywords": [
    "vue",
    "vue3",
    "linter",
    "static-analysis",
    "rules"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vue-doctor/core": "workspace:^0.1.1",
    "@vue/compiler-dom": "^3.5.13",
    "@vue/compiler-sfc": "^3.5.13",
    "ts-morph": "^25.0.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
